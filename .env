# ── LLM Provider — Google Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyBOy5Qnfb7Hg6Tmm9XIUv9CyknDFaQSf3E
LLM_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
LLM_PROVIDER=gemini

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Text Summarizer API"
APP_VERSION=1.0.0
DEBUG=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10        # requests per window
RATE_LIMIT_WINDOW=60          # window size in seconds

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL=3600                # seconds (1 hour)
CACHE_MAX_SIZE=500            # max entries
